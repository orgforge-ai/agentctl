{
  "name": "agentctl",
  "version": "0.1.0",
  "description": "Portable control plane for coding-agent harnesses",
  "type": "module",
  "bin": {
    "agentctl": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/cli/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=build/lib/agentctl.cjs",
    "dev": "tsc --watch",
    "release:build": "bash scripts/build-release.sh",
    "release:smoke": "bash scripts/release-smoke-test.sh",
    "start": "node dist/cli/index.js",
    "test": "tsx --test tests/runner.ts",
    "test:fast": "EXCLUDE_TAGS=api,slow tsx --test tests/runner.ts",
    "test:dry-run-only": "EXCLUDE_TAGS=api,slow,interactive,signal tsx --test tests/runner.ts",
    "test:manual": "tsx tests/manual-session.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.7",
    "strip-ansi": "^7.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
