{
  "name": "model-degraded-ok",
  "description": "Unknown model with --degraded-ok starts session without model flag",
  "command": "agentctl run -h {harness} --model nonexistent --degraded-ok",
  "tags": ["interactive"],
  "expected": {
    "claude": {
      "dryRun": "claude",
      "dryRunNotContains": "--model",
      "steps": [
        { "wait": "Claude Code", "timeoutMs": 15000 },
        { "send": "respond with only TEST_SUCCEEDED\\n" },
        { "wait": "/(?<!only )TEST_SUCCEEDED/", "timeoutMs": 30000 }
      ],
      "exitCode": 0
    },
    "opencode": {
      "dryRun": "opencode",
      "dryRunNotContains": "--model",
      "steps": [
        { "wait": "OpenCode", "timeoutMs": 15000 },
        { "send": "respond with only TEST_SUCCEEDED\\n" },
        { "wait": "/(?<!only )TEST_SUCCEEDED/", "timeoutMs": 30000 }
      ],
      "exitCode": 0
    }
  }
}
